# Copy this file to .env and fill in at least one key.
# Pixabay is tried first; Unsplash is used only if Pixabay's key is empty.

# Free, instant signup: https://pixabay.com/api/docs/
EXPO_PUBLIC_PIXABAY_KEY=

# Free, instant signup (use the "Access Key"): https://unsplash.com/developers
EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=
